SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
REDIS_URL=redis://localhost:6379/0
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...              # for text-embedding-3-small (embeddings only)
ALLOWED_ORIGINS=http://localhost:3000,https://mifcg-frontend.up.railway.app
ENVIRONMENT=development

# FXWatch — corridor breach alerts (all optional; polling/caching works without them,
# but no Slack/Telegram message is sent unless the relevant channel is configured)
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
FX_ALERT_THRESHOLD_PCT=0.5
FX_POLL_INTERVAL_MINUTES=5
