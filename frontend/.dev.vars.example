# Cloudflare Pages local dev secrets (rename to .dev.vars)
# These are injected by wrangler during `npm run preview:cf`
# For `npm run dev` (plain Next.js), use .env.local instead
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
